{
  "expo": {
    "name": "tracktrail",
    "slug": "tracktrail",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/logo.png",
    "scheme": "tracktrail",
    "userInterfaceStyle": "automatic",
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.bruno.tracktrail",
      "infoPlist": {
        "NSLocationWhenInUseUsageDescription": "O Track & Trail precisa da sua localização para rastrear suas atividades e rotas.",
        "NSLocationAlwaysUsageDescription": "O Track & Trail precisa da sua localização para rastrear suas atividades mesmo com a tela bloqueada.",
        "NSLocationAlwaysAndWhenInUseUsageDescription": "O Track & Trail usa localização em segundo plano para continuar gravando trilhas durante a atividade."
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/logo.png",
        "backgroundColor": "#ffffff"
      },
      "permissions": [
        "ACCESS_COARSE_LOCATION",
        "ACCESS_FINE_LOCATION",
        "ACCESS_BACKGROUND_LOCATION",
        "FOREGROUND_SERVICE",
        "FOREGROUND_SERVICE_LOCATION",
        "INTERNET",
        "android.permission.ACCESS_COARSE_LOCATION",
        "android.permission.ACCESS_FINE_LOCATION",
        "android.permission.FOREGROUND_SERVICE",
        "android.permission.FOREGROUND_SERVICE_LOCATION"
      ],
      "config": {
        "googleMaps": {
          "apiKey": "SET_VIA_EXPO_PUBLIC_GOOGLE_DIRECTIONS_API_KEY"
        }
      },
      "package": "com.bruno.tracktrail"
    },
    "web": {
      "bundler": "metro",
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/splash-icon.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#ffffff"
        }
      ],
      [
        "expo-location",
        {
          "locationAlwaysAndWhenInUsePermission": "Permitir que o Track & Trail acesse sua localização para mapear trilhas.",
          "isAndroidForegroundServiceEnabled": true
        }
      ],
      "expo-sqlite"
    ],
    "newArchEnabled": true,
    "typedRoutes": true,
    "extra": {
      "googleDirectionsApiKey": "SET_VIA_EXPO_PUBLIC_GOOGLE_DIRECTIONS_API_KEY",
      "firebaseFunctionsRegion": "us-central1",
      "firebase": {
        "apiKey": "SET_VIA_EXPO_PUBLIC_FIREBASE_API_KEY",
        "authDomain": "SET_VIA_EXPO_PUBLIC_FIREBASE_AUTH_DOMAIN",
        "databaseURL": "SET_VIA_EXPO_PUBLIC_FIREBASE_DATABASE_URL",
        "projectId": "SET_VIA_EXPO_PUBLIC_FIREBASE_PROJECT_ID",
        "storageBucket": "SET_VIA_EXPO_PUBLIC_FIREBASE_STORAGE_BUCKET",
        "messagingSenderId": "SET_VIA_EXPO_PUBLIC_FIREBASE_MESSAGING_SENDER_ID",
        "appId": "SET_VIA_EXPO_PUBLIC_FIREBASE_APP_ID"
      },
      "router": {},
      "eas": {
        "projectId": "b15aa9ff-e995-4b01-8c4d-b9be8953e564"
      }
    }
  }
}
